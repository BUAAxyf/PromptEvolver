# Training model configuration used by prompt-evolver run/optimize-step/test-step.
TRAIN_MODEL_NAME=
TRAIN_MODEL_API_BASE=
TRAIN_MODEL_API_KEY=
TRAIN_MODEL_TEMPERATURE=0
TRAIN_MODEL_MAX_TOKENS=2048
TRAIN_MODEL_TIMEOUT_SECONDS=90
TRAIN_MODEL_ENABLE_THINKING=true

# Independent evaluator model configuration used by blackbox-eval.
# Leave these blank to reuse the TRAIN_MODEL_* values.
EVALUATOR_MODEL_NAME=
EVALUATOR_MODEL_API_BASE=
EVALUATOR_MODEL_API_KEY=
EVALUATOR_MODEL_TEMPERATURE=
EVALUATOR_MODEL_MAX_TOKENS=
EVALUATOR_MODEL_TIMEOUT_SECONDS=
EVALUATOR_MODEL_ENABLE_THINKING=
