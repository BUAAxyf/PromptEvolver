{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt Evolver Judgement",
  "type": "object",
  "required": ["schema_version", "candidate_id", "judge", "case_judgements"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "judge": {
      "const": "codex"
    },
    "case_judgements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "binary_score",
          "score_100",
          "rationale",
          "failure_tags",
          "improvement_advice"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "binary_score": {
            "enum": [0, 1]
          },
          "score_100": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "rationale": {
            "type": "string"
          },
          "failure_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "improvement_advice": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "overall": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
